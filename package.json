{
  "name": "project-planner",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"npm run start:api\" \"npm run start:ng\"",
    "start:ng": "ng serve --proxy-config proxy.conf.json",
    "start:api": "nodemon --watch server --ext ts --exec \"ts-node --project server/tsconfig.json server/index.ts\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.8",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@anthropic-ai/sdk": "^0.91.1",
    "@ng-icons/core": "^29.10.0",
    "@ng-icons/heroicons": "^29.10.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "jest-preset-angular": "^16.1.4",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.1.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.0"
  }
}
